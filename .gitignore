# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/qa/

# local source photo intake; commit optimized files under processed/
/public/projects/limm-real/raw/**
!/public/projects/limm-real/raw/
!/public/projects/limm-real/raw/.gitkeep
!/public/projects/limm-real/raw/*/
!/public/projects/limm-real/raw/*/.gitkeep

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel
